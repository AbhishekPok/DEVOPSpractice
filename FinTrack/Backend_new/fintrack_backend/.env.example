# =============================================================================
# FinTrack Backend — Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# Django Settings
SECRET_KEY=generate-a-real-secret-key-with-python-manage-py-shell
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip-or-domain

# Database (PostgreSQL)
DB_NAME=fintrack_db
DB_USER=postgres
DB_PASSWORD=your-secure-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://your-server-ip:3000

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@fintrack.com

# API Rate Limiting
THROTTLE_ANON_RATE=100/day
THROTTLE_USER_RATE=1000/day

# Security (Production)
# For HTTPS production: Set all to True and SECURE_HSTS_SECONDS=31536000
# For HTTP staging (e.g. EC2 without SSL): Set all to False and SECURE_HSTS_SECONDS=0
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Logging
LOG_LEVEL=WARNING
DJANGO_LOG_LEVEL=WARNING
